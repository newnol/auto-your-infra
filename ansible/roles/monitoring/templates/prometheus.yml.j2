global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node_exporter'
    static_configs:
      - targets: ['node_exporter:9100']
        labels:
          instance: 'monitor-node'
      # Future nodes can be added here, e.g.,
      # - targets: ['192.168.1.59:9100']
      #   labels:
      #     instance: 'infra-node'
