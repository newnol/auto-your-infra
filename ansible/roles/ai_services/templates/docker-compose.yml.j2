services:

  # ---------------------------------------------------------------------------
  # Shared Infrastructure
  # ---------------------------------------------------------------------------

  postgres:
    image: postgres:16-alpine
    container_name: ai-postgres
    restart: unless-stopped
    volumes:
      - ./data/postgres:/var/lib/postgresql/data
      - ./init-databases.sh:/docker-entrypoint-initdb.d/init-databases.sh:ro
    environment:
      POSTGRES_USER: homelab
      POSTGRES_PASSWORD: "{{ app_db_password }}"
      POSTGRES_DB: homelab
    networks:
      - ai-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U homelab"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: ai-redis
    restart: unless-stopped
    volumes:
      - ./data/redis:/data
    networks:
      - ai-net
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ---------------------------------------------------------------------------
  # n8n -- Workflow Automation
  # ---------------------------------------------------------------------------

  n8n:
    image: n8nio/n8n:latest
    container_name: n8n
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    ports:
      - "5678:5678"
    volumes:
      - ./data/n8n:/home/node/.n8n
    environment:
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_PORT: "5432"
      DB_POSTGRESDB_DATABASE: n8n
      DB_POSTGRESDB_USER: homelab
      DB_POSTGRESDB_PASSWORD: "{{ app_db_password }}"
      N8N_HOST: "0.0.0.0"
      N8N_PORT: "5678"
      N8N_PROTOCOL: https
      WEBHOOK_URL: "https://n8n.{{ root_domain }}/"
      N8N_ENCRYPTION_KEY: "{{ n8n_encryption_key }}"
    networks:
      - ai-net

  # ---------------------------------------------------------------------------
  # SearXNG -- Privacy-respecting Metasearch Engine (AI agent tool)
  # ---------------------------------------------------------------------------

  searxng:
    image: searxng/searxng:latest
    container_name: searxng
    restart: unless-stopped
    ports:
      - "8080:8080"
    volumes:
      - ./searxng/settings.yml:/etc/searxng/settings.yml:ro
    networks:
      - ai-net

  # ---------------------------------------------------------------------------
  # Qdrant -- Vector Database for RAG pipelines
  # ---------------------------------------------------------------------------

  qdrant:
    image: qdrant/qdrant:latest
    container_name: qdrant
    restart: unless-stopped
    ports:
      - "6333:6333"
      - "6334:6334"
    volumes:
      - ./data/qdrant:/qdrant/storage
    networks:
      - ai-net

  # ---------------------------------------------------------------------------
  # Langfuse -- LLM Observability & Tracing
  # ---------------------------------------------------------------------------

  langfuse:
    image: langfuse/langfuse:2
    container_name: langfuse
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    ports:
      - "3003:3000"
    environment:
      DATABASE_URL: "postgresql://homelab:{{ app_db_password }}@postgres:5432/langfuse"
      NEXTAUTH_SECRET: "{{ langfuse_secret_key }}"
      SALT: "{{ langfuse_salt }}"
      NEXTAUTH_URL: "https://langfuse.{{ root_domain }}"
      TELEMETRY_ENABLED: "false"
    networks:
      - ai-net

  # ---------------------------------------------------------------------------
  # Dify -- LLM App Development Platform
  # ---------------------------------------------------------------------------

  dify-api:
    image: langgenius/dify-api:latest
    container_name: dify-api
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    volumes:
      - ./data/dify/storage:/app/api/storage
    environment:
      MODE: api
      LOG_LEVEL: INFO
      SECRET_KEY: "{{ dify_secret_key }}"
      CONSOLE_WEB_URL: "https://dify.{{ root_domain }}"
      CONSOLE_API_URL: "https://dify.{{ root_domain }}"
      SERVICE_API_URL: "https://dify.{{ root_domain }}"
      APP_WEB_URL: "https://dify.{{ root_domain }}"
      FILES_ACCESS_TIMEOUT: "300"
      MIGRATION_ENABLED: "true"
      DB_USERNAME: homelab
      DB_PASSWORD: "{{ app_db_password }}"
      DB_HOST: postgres
      DB_PORT: "5432"
      DB_DATABASE: dify
      REDIS_HOST: redis
      REDIS_PORT: "6379"
      REDIS_DB: "1"
      CELERY_BROKER_URL: "redis://redis:6379/1"
      VECTOR_STORE: qdrant
      QDRANT_URL: "http://qdrant:6333"
      QDRANT_CLIENT_TIMEOUT: "20"
      CODE_EXECUTION_ENDPOINT: "http://dify-sandbox:8194"
      CODE_EXECUTION_API_KEY: "{{ dify_sandbox_key }}"
      STORAGE_TYPE: local
      STORAGE_LOCAL_PATH: storage
    networks:
      - ai-net

  dify-worker:
    image: langgenius/dify-api:latest
    container_name: dify-worker
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    volumes:
      - ./data/dify/storage:/app/api/storage
    environment:
      MODE: worker
      LOG_LEVEL: INFO
      SECRET_KEY: "{{ dify_secret_key }}"
      DB_USERNAME: homelab
      DB_PASSWORD: "{{ app_db_password }}"
      DB_HOST: postgres
      DB_PORT: "5432"
      DB_DATABASE: dify
      REDIS_HOST: redis
      REDIS_PORT: "6379"
      REDIS_DB: "1"
      CELERY_BROKER_URL: "redis://redis:6379/1"
      VECTOR_STORE: qdrant
      QDRANT_URL: "http://qdrant:6333"
      QDRANT_CLIENT_TIMEOUT: "20"
      CODE_EXECUTION_ENDPOINT: "http://dify-sandbox:8194"
      CODE_EXECUTION_API_KEY: "{{ dify_sandbox_key }}"
      STORAGE_TYPE: local
      STORAGE_LOCAL_PATH: storage
    networks:
      - ai-net

  dify-web:
    image: langgenius/dify-web:latest
    container_name: dify-web
    restart: unless-stopped
    environment:
      CONSOLE_API_URL: ""
      APP_API_URL: ""
      SENTRY_DSN: ""
    networks:
      - ai-net

  dify-sandbox:
    image: langgenius/dify-sandbox:latest
    container_name: dify-sandbox
    restart: unless-stopped
    environment:
      API_KEY: "{{ dify_sandbox_key }}"
      GIN_MODE: release
      WORKER_TIMEOUT: "15"
    networks:
      - ai-net

  dify-nginx:
    image: nginx:alpine
    container_name: dify-nginx
    restart: unless-stopped
    depends_on:
      - dify-api
      - dify-web
    ports:
      - "3004:80"
    volumes:
      - ./dify-nginx.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - ai-net

  # ---------------------------------------------------------------------------
  # Node Exporter -- Host metrics for Prometheus
  # ---------------------------------------------------------------------------

  node_exporter:
    image: prom/node-exporter:latest
    container_name: node_exporter
    restart: unless-stopped
    network_mode: "host"
    pid: "host"
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - "--path.procfs=/host/proc"
      - "--path.rootfs=/rootfs"
      - "--path.sysfs=/host/sys"
      - "--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)"

networks:
  ai-net:
    driver: bridge
